# ============================================
# Toolbox 环境变量模板
# 复制为 .env 填入真实值（.env 已被 gitignore）
# ============================================

# 部署目标 — VPS SSH 信息和路径
DEPLOY_HOST=your-vps-tailscale-hostname
DEPLOY_WWW=/path/to/www/on/vps

# Caddy Docker 配置（仅首次部署时需要）
CADDY_CONFIG=/path/to/Caddyfile
CADDY_COMPOSE_DIR=/path/to/caddy/docker-compose/dir

# 可选: Google Analytics
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
