# Toolbox manual deployment values
#
# Copy this file to deploy/.env and replace every placeholder.
# deploy/.env is gitignored and must never be committed.

# SSH alias or user@host. Do not put the real value in documentation or commits.
VPS_HOST={{SSH_TARGET}}

# SSH port. Keep the real value only in deploy/.env or CI secrets.
VPS_PORT={{SSH_PORT}}

# Remote web root, for example an absolute or home-relative path.
VPS_WWW={{REMOTE_WEB_ROOT}}
