# deploy/Caddyfile.example
# Append to the private VPS Caddyfile, then restart Caddy.
# Keep the real site domain and container web root in private deployment config.

{{VPS_SITE_DOMAIN}} {
    root * {{VPS_CONTAINER_WEB_ROOT}}
    file_server
    encode gzip zstd

    handle /rate-lens/* {
        try_files {path} /rate-lens/index.html
    }
    handle /chrono-sphere/* {
        try_files {path} /chrono-sphere/index.html
    }
    handle /sane-units/* {
        try_files {path} /sane-units/index.html
    }

    handle {
        file_server
    }
}
